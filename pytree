#!/data/data/com.termux/files/usr/bin/bash

BLUE='\033[1;34m'
GREEN='\033[1;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

OS_INFO=$(uname -o)
PY_VER=$(python3 -V 2>&1 | awk '{print $2}')
TARGET_DIR=${1:-.}

echo -e "${BLUE}PyTree @ $OS_INFO | Python v${PY_VER}${NC}"
echo "------------------------------------------"

# Folosim find pentru a genera lista de fișiere
# Apoi pasăm lista către un singur proces awk care procesează totul
find "$TARGET_DIR" -name "*.py" -not -path "*/.*" -not -path "*__pycache__*" | xargs awk '
    BEGINFILE { 
        has_funcs = 0; 
        file_content = ""; 
        line_count = 0;
    }
    # Numărăm liniile și căutăm funcții
    { 
        line_count++;
        if ($0 ~ /^[[:space:]]*(async[[:space:]]+)?def [^_]/) {
            has_funcs = 1;
            name = $0;
            # Curățăm numele funcției direct în awk
            sub(/^[[:space:]]*(async[[:space:]]+)?def /, "  ├── ", name);
            sub(/\(.*/, "()", name);
            
            # Adăugăm marcajul async colorat (codurile ANSI trebuie puse manual)
            if ($0 ~ /async/) {
                name = name " \033[0;36m⚡(async)\033[0m";
            }
            file_content = file_content name "\n";
        }
    }
    ENDFILE {
        if (has_funcs) {
            printf "\033[1;32m📂 %s \033[1;33m[%d lines]\033[0m\n", FILENAME, line_count;
            printf "%s\n", file_content;
        }
    }'
